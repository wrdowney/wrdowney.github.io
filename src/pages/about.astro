---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About">
  <section class="section">
    <div class="shell about">
      <header class="about__header">
        <p class="eyebrow">About</p>
        <h1>Software, writing, and durable systems.</h1>
      </header>
      <div class="about__body panel">
        <div class="prose">
          <p>
            This site is designed as a personal publishing system rather than a portfolio template. The goal is
            to make writing, projects, and ongoing work feel like parts of the same practice.
          </p>
          <p>
            The visual direction takes cues from editorial design and industrial systems: sharp type, structured
            spacing, visible metadata, and a preference for clarity over ornament.
          </p>
          <p>
            Replace this page with your biography, approach to engineering, and the kinds of problems you want to
            be hired for or collaborate on.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    display: grid;
    gap: var(--space-5);
  }

  .about__header h1 {
    margin: 0.75rem 0 0;
    max-width: 10ch;
    font-family: var(--font-sans);
    font-size: clamp(3rem, 2rem + 3vw, 5rem);
    line-height: 0.9;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .about__body {
    padding: clamp(1.2rem, 3vw, 3rem);
  }
</style>
