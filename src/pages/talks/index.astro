---
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const talks = await getCollection('talks');
const sortedTalks = talks.sort((a: CollectionEntry<'talks'>, b: CollectionEntry<'talks'>) => b.data.date.valueOf() - a.data.date.valueOf());

const upcomingTalks = sortedTalks.filter((talk: CollectionEntry<'talks'>) => talk.data.upcoming);
const pastTalks = sortedTalks.filter((talk: CollectionEntry<'talks'>) => !talk.data.upcoming);

// Get all unique tags
const allTags = [...new Set((talks as CollectionEntry<'talks'>[]).flatMap(talk => talk.data.tags))].sort() as string[];
---

<Layout title="Talks - Will Downey" description="Speaking engagements on iOS development and mobile engineering">
  <Header />
  
  <main class="flex-1 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-4xl font-bold mb-4">Talks</h1>
          <p class="text-lg text-muted-foreground">
            Speaking engagements on iOS development, SwiftUI, platform architecture, and mobile engineering best practices.
          </p>
        </div>
        
        <!-- Tags -->
        {allTags.length > 0 && (
          <div class="mb-12">
            <h2 class="text-sm font-medium text-muted-foreground mb-3 uppercase tracking-wider">Topics</h2>
            <div class="flex flex-wrap gap-2">
              {allTags.map((tag: string) => (
                <span class="px-3 py-1.5 text-sm font-medium bg-muted text-muted-foreground rounded-lg">
                  {tag}
                </span>
              ))}
            </div>
          </div>
        )}
        
        <!-- Upcoming Talks -->
        {upcomingTalks.length > 0 && (
          <section class="mb-12">
            <h2 class="text-2xl font-semibold mb-6">Upcoming</h2>
            <div class="space-y-6">
              {upcomingTalks.map((talk: CollectionEntry<'talks'>) => (
                <article class="group p-6 rounded-xl border border-primary/20 bg-primary/5">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex flex-wrap gap-2 mb-3">
                        {talk.data.tags.map((tag: string) => (
                          <span class="text-xs font-medium text-muted-foreground bg-background px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                        <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded">
                          Upcoming
                        </span>
                      </div>
                      <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
                        <a href={`/talks/${talk.slug}/`}>
                          {talk.data.title}
                        </a>
                      </h3>
                      <p class="text-muted-foreground mb-3">
                        {talk.data.description}
                      </p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                        <span class="font-medium text-foreground">{talk.data.venue}</span>
                        {talk.data.location && (
                          <span>{talk.data.location}</span>
                        )}
                        <time datetime={talk.data.date.toISOString()}>
                          {talk.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </section>
        )}
        
        <!-- Past Talks -->
        <section>
          <h2 class="text-2xl font-semibold mb-6">Past Talks</h2>
          {pastTalks.length > 0 ? (
            <div class="space-y-6">
              {pastTalks.map((talk: CollectionEntry<'talks'>) => (
                <article class="group p-6 rounded-xl border border-border bg-card hover:border-primary/50 transition-colors">
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex flex-wrap gap-2 mb-3">
                        {talk.data.tags.map((tag: string) => (
                          <span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                      <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
                        <a href={`/talks/${talk.slug}/`}>
                          {talk.data.title}
                        </a>
                      </h3>
                      <p class="text-muted-foreground mb-3">
                        {talk.data.description}
                      </p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                        <span class="font-medium text-foreground">{talk.data.venue}</span>
                        {talk.data.location && (
                          <span>{talk.data.location}</span>
                        )}
                        <time datetime={talk.data.date.toISOString()}>
                          {talk.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      </div>
                      {(talk.data.slides || talk.data.video) && (
                        <div class="flex gap-4 mt-4 pt-4 border-t border-border">
                          {talk.data.slides && (
                            <a 
                              href={talk.data.slides}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 font-medium"
                            >
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                              </svg>
                              Slides
                            </a>
                          )}
                          {talk.data.video && (
                            <a 
                              href={talk.data.video}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 font-medium"
                            >
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              Video
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div class="text-center py-12 text-muted-foreground">
              No past talks yet.
            </div>
          )}
        </section>
      </div>
    </div>
  </main>
  
  <Footer />
</Layout>
