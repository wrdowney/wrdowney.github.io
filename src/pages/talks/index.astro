---
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const talks = await getCollection('talks');
const sortedTalks = talks.sort((a: CollectionEntry<'talks'>, b: CollectionEntry<'talks'>) => b.data.date.valueOf() - a.data.date.valueOf());

const upcomingTalks = sortedTalks.filter((talk: CollectionEntry<'talks'>) => talk.data.upcoming);
const pastTalks = sortedTalks.filter((talk: CollectionEntry<'talks'>) => !talk.data.upcoming);

// Get all unique tags
const allTags = [...new Set((talks as CollectionEntry<'talks'>[]).flatMap(talk => talk.data.tags))].sort() as string[];
---

<Layout title="Talks - Will Downey" description="Speaking engagements on iOS development and mobile engineering">
  <Header />
  
  <main class="flex-1 py-16">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-12">
          <h1 class="text-4xl font-bold mb-4">Talks</h1>
          <p class="text-lg text-muted-foreground">
            Speaking engagements on iOS development, SwiftUI, platform architecture, and mobile engineering best practices.
          </p>
        </div>
        
        <!-- Tags Filter -->
        {allTags.length > 0 && (
          <div class="mb-12">
            <div class="flex items-center justify-between mb-3">
              <h2 class="text-sm font-medium text-muted-foreground uppercase tracking-wider">Topics</h2>
              <button
                id="clear-filter"
                class="hidden text-sm text-primary hover:text-primary/80 font-medium transition-colors"
              >
                Clear filter
              </button>
            </div>
            <div class="flex flex-wrap gap-2" id="tags-container">
              {allTags.map((tag: string) => (
                <button
                  class="tag-filter inline-flex items-center px-4 py-1.5 text-sm font-medium border rounded-full transition-all duration-200 cursor-pointer hover:shadow-sm"
                  data-tag={tag}
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        )}
        
        <!-- Filter Status -->
        <div id="filter-status" class="hidden mb-6 p-4 rounded-lg bg-primary/5 border border-primary/20">
          <p class="text-sm text-muted-foreground">
            Showing talks tagged with <span id="active-filter" class="font-semibold text-primary"></span>
            <span id="result-count" class="ml-2"></span>
          </p>
        </div>
        
        <!-- Upcoming Talks -->
        <section class="mb-12" id="upcoming-section">
          <h2 class="text-2xl font-semibold mb-6">Upcoming</h2>
          {upcomingTalks.length > 0 ? (
            <div class="space-y-6" id="upcoming-container">
              {upcomingTalks.map((talk: CollectionEntry<'talks'>) => (
                <article 
                  class="talk-item group p-6 rounded-xl border border-primary/20 bg-primary/5"
                  data-tags={JSON.stringify(talk.data.tags)}
                  data-type="upcoming"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex flex-wrap gap-2 mb-3">
                        {talk.data.tags.map((tag: string) => (
                          <span class="text-xs font-medium text-muted-foreground bg-background px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                        <span class="text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded">
                          Upcoming
                        </span>
                      </div>
                      <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
                        <a href={`/talks/${talk.slug}/`}>
                          {talk.data.title}
                        </a>
                      </h3>
                      <p class="text-muted-foreground mb-3">
                        {talk.data.description}
                      </p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                        <span class="font-medium text-foreground">{talk.data.venue}</span>
                        {talk.data.location && (
                          <span>{talk.data.location}</span>
                        )}
                        <time datetime={talk.data.date.toISOString()}>
                          {talk.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      </div>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div id="upcoming-empty" class="text-center py-8 text-muted-foreground hidden">
              No upcoming talks with this tag.
            </div>
          )}
          <div id="upcoming-no-talks" class="text-center py-8 text-muted-foreground">
            No upcoming talks scheduled.
          </div>
        </section>
        
        <!-- Past Talks -->
        <section id="past-section">
          <h2 class="text-2xl font-semibold mb-6">Past Talks</h2>
          {pastTalks.length > 0 ? (
            <div class="space-y-6" id="past-container">
              {pastTalks.map((talk: CollectionEntry<'talks'>) => (
                <article 
                  class="talk-item group p-6 rounded-xl border border-border bg-card hover:border-primary/50 transition-colors"
                  data-tags={JSON.stringify(talk.data.tags)}
                  data-type="past"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="flex-1">
                      <div class="flex flex-wrap gap-2 mb-3">
                        {talk.data.tags.map((tag: string) => (
                          <span class="text-xs font-medium text-muted-foreground bg-muted px-2 py-1 rounded">
                            {tag}
                          </span>
                        ))}
                      </div>
                      <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
                        <a href={`/talks/${talk.slug}/`}>
                          {talk.data.title}
                        </a>
                      </h3>
                      <p class="text-muted-foreground mb-3">
                        {talk.data.description}
                      </p>
                      <div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
                        <span class="font-medium text-foreground">{talk.data.venue}</span>
                        {talk.data.location && (
                          <span>{talk.data.location}</span>
                        )}
                        <time datetime={talk.data.date.toISOString()}>
                          {talk.data.date.toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric',
                          })}
                        </time>
                      </div>
                      {(talk.data.slides || talk.data.video) && (
                        <div class="flex gap-4 mt-4 pt-4 border-t border-border">
                          {talk.data.slides && (
                            <a 
                              href={talk.data.slides}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 font-medium"
                            >
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                              </svg>
                              Slides
                            </a>
                          )}
                          {talk.data.video && (
                            <a 
                              href={talk.data.video}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="inline-flex items-center gap-2 text-sm text-primary hover:text-primary/80 font-medium"
                            >
                              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                              </svg>
                              Video
                            </a>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          ) : (
            <div id="past-no-talks" class="text-center py-12 text-muted-foreground">
              No past talks yet.
            </div>
          )}
          <div id="past-empty" class="hidden text-center py-12 text-muted-foreground">
            <p class="mb-4">No talks found with this tag.</p>
            <button
              id="empty-clear-filter"
              class="text-sm text-primary hover:text-primary/80 font-medium transition-colors"
            >
              Clear filter
            </button>
          </div>
        </section>
      </div>
    </div>
  </main>
  
  <Footer />
  
  <script>
    // Get DOM elements
    const tagButtons = document.querySelectorAll('.tag-filter');
    const talkItems = document.querySelectorAll('.talk-item');
    const clearFilterBtn = document.getElementById('clear-filter');
    const emptyClearFilterBtn = document.getElementById('empty-clear-filter');
    const filterStatus = document.getElementById('filter-status');
    const activeFilterSpan = document.getElementById('active-filter');
    const resultCountSpan = document.getElementById('result-count');
    const upcomingSection = document.getElementById('upcoming-section');
    const pastSection = document.getElementById('past-section');
    const upcomingEmpty = document.getElementById('upcoming-empty');
    const pastEmpty = document.getElementById('past-empty');
    const upcomingNoTalks = document.getElementById('upcoming-no-talks');
    const pastNoTalks = document.getElementById('past-no-talks');
    const upcomingContainer = document.getElementById('upcoming-container');
    const pastContainer = document.getElementById('past-container');
    
    let currentFilter: string | null = null;
    
    // Function to filter talks
    function filterTalks(tag: string) {
      currentFilter = tag;
      let upcomingCount = 0;
      let pastCount = 0;
      
      talkItems.forEach((item: Element) => {
        const htmlItem = item as HTMLElement;
        const itemTags = JSON.parse(htmlItem.dataset.tags || '[]');
        const itemType = htmlItem.dataset.type;
        
        if (itemTags.includes(tag)) {
          htmlItem.style.display = '';
          if (itemType === 'upcoming') {
            upcomingCount++;
          } else {
            pastCount++;
          }
        } else {
          htmlItem.style.display = 'none';
        }
      });
      
      // Update UI
      updateFilterUI(tag, upcomingCount, pastCount);
      
      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.set('tag', tag);
      window.history.pushState({}, '', url);
    }
    
    // Function to clear filter
    function clearFilter() {
      currentFilter = null;
      
      talkItems.forEach((item: Element) => {
        const htmlItem = item as HTMLElement;
        htmlItem.style.display = '';
      });
      
      // Update UI - remove active class from all badges
      tagButtons.forEach((btn: Element) => {
        btn.classList.remove('active');
      });
      
      clearFilterBtn?.classList.add('hidden');
      filterStatus?.classList.add('hidden');
      
      // Show sections
      upcomingSection?.classList.remove('hidden');
      pastSection?.classList.remove('hidden');
      upcomingEmpty?.classList.add('hidden');
      pastEmpty?.classList.add('hidden');
      
      // Check if sections have content
      const hasUpcoming = document.querySelectorAll('.talk-item[data-type="upcoming"]').length > 0;
      const hasPast = document.querySelectorAll('.talk-item[data-type="past"]').length > 0;
      
      if (!hasUpcoming) {
        upcomingNoTalks?.classList.remove('hidden');
      }
      if (!hasPast) {
        pastNoTalks?.classList.remove('hidden');
      }
      
      // Update URL
      const url = new URL(window.location.href);
      url.searchParams.delete('tag');
      window.history.pushState({}, '', url);
    }
    
    // Function to update filter UI
    function updateFilterUI(tag: string, upcomingCount: number, pastCount: number) {
      const totalCount = upcomingCount + pastCount;
      
      // Update tag buttons - active badge gets 'active' class
      tagButtons.forEach((btn: Element) => {
        const htmlBtn = btn as HTMLElement;
        if (htmlBtn.dataset.tag === tag) {
          htmlBtn.classList.add('active');
        } else {
          htmlBtn.classList.remove('active');
        }
      });
      
      // Show/hide clear button
      clearFilterBtn?.classList.remove('hidden');
      
      // Update filter status
      if (filterStatus && activeFilterSpan && resultCountSpan) {
        filterStatus.classList.remove('hidden');
        activeFilterSpan.textContent = tag;
        resultCountSpan.textContent = `(${totalCount} talk${totalCount !== 1 ? 's' : ''})`;
      }
      
      // Handle empty states
      if (upcomingCount === 0) {
        upcomingContainer?.classList.add('hidden');
        upcomingEmpty?.classList.remove('hidden');
      } else {
        upcomingContainer?.classList.remove('hidden');
        upcomingEmpty?.classList.add('hidden');
      }
      
      if (pastCount === 0) {
        pastContainer?.classList.add('hidden');
        pastNoTalks?.classList.add('hidden');
        pastEmpty?.classList.remove('hidden');
      } else {
        pastContainer?.classList.remove('hidden');
        pastEmpty?.classList.add('hidden');
      }
    }
    
    // Add click handlers to tag buttons
    tagButtons.forEach((button: Element) => {
      const htmlButton = button as HTMLElement;
      htmlButton.addEventListener('click', () => {
        const tag = htmlButton.dataset.tag;
        if (tag) {
          if (currentFilter === tag) {
            clearFilter();
          } else {
            filterTalks(tag);
          }
        }
      });
    });
    
    // Add click handlers to clear buttons
    clearFilterBtn?.addEventListener('click', clearFilter);
    emptyClearFilterBtn?.addEventListener('click', clearFilter);
    
    // Initialize - hide "no talks" messages if there are talks
    const hasUpcoming = document.querySelectorAll('.talk-item[data-type="upcoming"]').length > 0;
    const hasPast = document.querySelectorAll('.talk-item[data-type="past"]').length > 0;
    
    if (hasUpcoming) {
      upcomingNoTalks?.classList.add('hidden');
    }
    if (hasPast) {
      pastNoTalks?.classList.add('hidden');
    }
    
    // Check URL for existing filter on page load
    const urlParams = new URLSearchParams(window.location.search);
    const initialTag = urlParams.get('tag');
    if (initialTag) {
      filterTalks(initialTag);
    }
  </script>
</Layout>
