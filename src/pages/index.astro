---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import PostCard from "../components/PostCard.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionHeader from "../components/SectionHeader.astro";
import { siteConfig } from "../data/site";

const featuredPosts = (await getCollection("blog", ({ data }) => !data.draft && data.featured))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);

const featuredProjects = (await getCollection("projects", ({ data }) => data.featured))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 2);
---

<BaseLayout>
  <Hero
    eyebrow={siteConfig.home.eyebrow}
    title={siteConfig.home.title}
    intro={siteConfig.home.intro}
  />

  <section class="section">
    <div class="shell">
      <SectionHeader
        eyebrow="Featured writing"
        title="Recent essays and writing"
        copy="Longer writing on software, design, systems, and the habits that improve technical judgment over time."
      />
      <div class="home-grid">
        {
          featuredPosts.map((post) => (
            <PostCard
              href={`/blog/${post.id}/`}
              title={post.data.title}
              summary={post.data.summary}
              date={post.data.publishedAt}
              tags={post.data.tags}
            />
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section--tight">
    <div class="shell">
      <SectionHeader
        eyebrow="Selected work"
        title="Projects with a clear point of view"
        copy="A compact set of case studies and experiments that show the kinds of systems, products, and interfaces I care about."
      />
      <div class="project-grid">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              href={`/projects/${project.id}/`}
              title={project.data.title}
              summary={project.data.summary}
              year={project.data.year}
              status={project.data.status}
              stack={project.data.stack}
              links={project.data.links}
            />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .home-grid,
  .project-grid {
    display: grid;
    gap: var(--space-4);
  }

  .home-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .project-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .section--tight {
    padding-top: 0;
  }

  @media (max-width: 980px) {
    .home-grid {
      grid-template-columns: 1fr;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
