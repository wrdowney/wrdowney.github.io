---
import { type CollectionEntry, getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { readingTime } from "@lib/utils";
import BackToPrev from "@components/BackToPrev.astro";
import MaterialsBadge from "@components/MaterialsBadge.astro";
import TagBadge from "@components/TagBadge.astro";
import { BLOG, SITE } from "@consts";

export async function getStaticPaths() {
  const posts = (await getCollection("blog"))
    .filter(post => !post.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}
type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();
const blogRssHref = "/blog/rss.xml";
const blogRssTitle = `${SITE.NAME} ${BLOG.TITLE}`;
---

<PageLayout
  title={post.data.title}
  description={post.data.description}
  rssHref={blogRssHref}
  rssTitle={blogRssTitle}
>
  <Container>
    <div class="animate">
      <BackToPrev href="/blog">
        Back to blog
      </BackToPrev>
    </div>
    <div class="space-y-1 my-10">
      <div class="animate flex items-center gap-1.5">
        <div class="font-base text-sm">
          <FormattedDate date={post.data.date} />
        </div>
        &bull;
        <div class="font-base text-sm">
          {readingTime(post.body)}
        </div>
      </div>
      <div class="animate text-2xl font-semibold text-black dark:text-white">
        {post.data.title}
      </div>
      {(post.data.materials || (post.data.tags && post.data.tags.length > 0)) && (
        <div class="animate flex flex-wrap gap-2 pt-2">
          {post.data.materials && (
            <MaterialsBadge
              href={post.data.materials.href}
              label={post.data.materials.label}
            />
          )}
          {post.data.tags?.map((tag) => (
            <TagBadge label={tag} />
          ))}
        </div>
      )}
    </div>
    <article class="animate">
      <Content />
    </article>
  </Container>
</PageLayout>
