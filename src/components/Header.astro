---
import { siteConfig } from "../data/site";

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="site-header__mark" href="/">
      <span class="site-header__name">{siteConfig.author}</span>
      <span class="site-header__role">Systems / Software / Writing</span>
    </a>

    <nav aria-label="Primary">
      <ul class="site-header__nav">
        {
          siteConfig.nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={{
                  "is-active": pathname === item.href || pathname.startsWith(`${item.href}/`)
                }}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    padding: 1rem 0;
    backdrop-filter: blur(16px);
    background: linear-gradient(180deg, rgba(6, 12, 10, 0.94), rgba(6, 12, 10, 0.58));
    border-bottom: 1px solid var(--color-line);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .site-header__mark {
    display: grid;
    gap: 0.15rem;
  }

  .site-header__name {
    font-family: var(--font-sans);
    font-size: 1.15rem;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .site-header__role {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .site-header__nav {
    display: flex;
    gap: 0.5rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-header__nav a {
    display: inline-flex;
    padding: 0.65rem 0.9rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-muted);
    transition:
      transform 180ms ease,
      background 180ms ease,
      color 180ms ease;
  }

  .site-header__nav a:hover,
  .site-header__nav a.is-active {
    color: var(--color-ink);
    background: rgba(116, 242, 139, 0.12);
    transform: translateY(-1px);
  }

  @media (max-width: 720px) {
    .site-header__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-header__nav {
      flex-wrap: wrap;
    }
  }
</style>
