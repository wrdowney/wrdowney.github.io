---
import { siteConfig } from "../data/site";
---

<footer class="site-footer">
  <div class="shell site-footer__inner panel">
    <div>
      <p class="eyebrow">Built to publish</p>
      <p class="site-footer__lead">
        Writing, software, and long-running work deserve an interface with some structure.
      </p>
    </div>

    <div class="site-footer__meta">
      <a href={siteConfig.social.github}>GitHub</a>
      <a href={siteConfig.social.linkedin}>LinkedIn</a>
      <a href={siteConfig.social.rss}>RSS</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 0 var(--space-6);
  }

  .site-footer__inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5);
  }

  .site-footer__lead {
    max-width: 30rem;
    margin: 0.75rem 0 0;
    font-size: var(--text-lg);
  }

  .site-footer__meta {
    display: flex;
    gap: 1rem;
    align-items: flex-end;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .site-footer__meta a {
    color: var(--color-muted);
  }

  .site-footer__meta a:hover {
    color: var(--color-accent);
    text-shadow: 0 0 18px rgba(116, 242, 139, 0.24);
  }

  @media (max-width: 720px) {
    .site-footer__inner {
      flex-direction: column;
    }

    .site-footer__meta {
      align-items: flex-start;
      flex-wrap: wrap;
    }
  }
</style>
