---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import { SITE } from "@consts";

type Props = {
  title: string;
  description: string;
  rssHref?: string;
  rssTitle?: string;
};

const { description, rssHref, rssTitle } = Astro.props;
---

<!doctype html>
<html lang="en" transition:animate="none">
  <head>
    <Head
      title={SITE.NAME}
      description={description}
      rssHref={rssHref}
      rssTitle={rssTitle}
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
